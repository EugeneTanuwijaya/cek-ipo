# Token bearer untuk endpoint admin (mis. POST /api/admin/scrape).
# Wajib diisi dengan nilai acak yang kuat sebelum deploy ke produksi.
ADMIN_TOKEN=

# Domain publik yang dipakai Caddy untuk TLS otomatis (Let's Encrypt),
# mis. DOMAIN=saham-ipo.example.com
# Untuk pengujian lokal isi "http://localhost" (HTTP polos, tanpa redirect);
# jika dikosongkan Caddy memakai "localhost" dengan sertifikat internal dan
# me-redirect port 80 ke HTTPS (308).
DOMAIN=
